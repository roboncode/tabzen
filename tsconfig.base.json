{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@tab-zen/shared": ["packages/shared/src/index.ts"],
      "@tab-zen/content-types": ["packages/content-types/src/index.ts"]
    }
  }
}
